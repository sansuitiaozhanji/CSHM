<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.mapper.CarouselMapper">

    <resultMap id="carouselMap" type="com.campus.entity.Carousel">
        <id property="id" column="id"/>
        <result property="imageUrl" column="image_url"/>
        <result property="linkUrl" column="link_url"/>
        <result property="title" column="title"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="carouselMap">
        SELECT * FROM carousel WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="carouselMap">
        SELECT * FROM carousel ORDER BY sort_order ASC
    </select>

    <select id="findActive" resultMap="carouselMap">
        SELECT * FROM carousel WHERE status = 1 ORDER BY sort_order ASC
    </select>

    <insert id="insert" parameterType="com.campus.entity.Carousel" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO carousel (image_url, link_url, title, sort_order, status, created_at)
        VALUES (#{imageUrl}, #{linkUrl}, #{title}, #{sortOrder}, #{status}, NOW())
    </insert>

    <update id="update" parameterType="com.campus.entity.Carousel">
        UPDATE carousel SET image_url = #{imageUrl}, link_url = #{linkUrl}, title = #{title},
                            sort_order = #{sortOrder}, status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM carousel WHERE id = #{id}
    </delete>

</mapper>
