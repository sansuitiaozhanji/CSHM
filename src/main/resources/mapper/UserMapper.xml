<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.mapper.UserMapper">

    <resultMap id="userMap" type="com.campus.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="phone" column="phone"/>
        <result property="avatar" column="avatar"/>
        <result property="balance" column="balance"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="userMap">
        SELECT * FROM `user` WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="userMap">
        SELECT * FROM `user` WHERE username = #{username}
    </select>

    <select id="findByPhone" resultMap="userMap">
        SELECT * FROM `user` WHERE phone = #{phone}
    </select>

    <select id="findByAccount" resultMap="userMap">
        SELECT * FROM `user` WHERE username = #{account} OR phone = #{account}
    </select>

    <insert id="insert" parameterType="com.campus.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (username, password, phone, avatar, balance, role, status, created_at, updated_at)
        VALUES (#{username}, #{password}, #{phone}, #{avatar}, #{balance}, #{role}, #{status}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.campus.entity.User">
        UPDATE `user`
        SET phone = #{phone}, avatar = #{avatar}, updated_at = NOW()
        WHERE id = #{id}
    </update>

    <update id="updatePassword">
        UPDATE `user` SET password = #{password}, updated_at = NOW() WHERE id = #{id}
    </update>

    <update id="updateBalance">
        UPDATE `user` SET balance = #{balance}, updated_at = NOW() WHERE id = #{id}
    </update>

    <select id="findAll" resultMap="userMap">
        SELECT * FROM `user`
        <where>
            <if test="keyword != null and keyword != ''">
                username LIKE CONCAT('%', #{keyword}, '%')
                OR phone LIKE CONCAT('%', #{keyword}, '%')
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <update id="updateStatus">
        UPDATE `user` SET status = #{status}, updated_at = NOW() WHERE id = #{id}
    </update>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM `user`
    </select>

    <select id="countByStatus" resultType="long">
        SELECT COUNT(*) FROM `user` WHERE status = #{status}
    </select>

</mapper>
