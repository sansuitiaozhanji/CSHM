<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.mapper.ImageMapper">

    <resultMap id="imageMap" type="com.campus.entity.Image">
        <id property="id" column="id"/>
        <result property="productId" column="product_id"/>
        <result property="url" column="url"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="imageMap">
        SELECT * FROM image WHERE id = #{id}
    </select>

    <select id="findByProductId" resultMap="imageMap">
        SELECT * FROM image WHERE product_id = #{productId} ORDER BY sort_order ASC
    </select>

    <select id="findByProductIds" resultMap="imageMap">
        SELECT * FROM image WHERE product_id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY product_id, sort_order ASC
    </select>

    <insert id="insert" parameterType="com.campus.entity.Image" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO image (product_id, url, sort_order, created_at)
        VALUES (#{productId}, #{url}, #{sortOrder}, NOW())
    </insert>

    <insert id="batchInsert">
        INSERT INTO image (product_id, url, sort_order, created_at)
        VALUES
        <foreach collection="images" item="img" separator=",">
            (#{img.productId}, #{img.url}, #{img.sortOrder}, NOW())
        </foreach>
    </insert>

    <delete id="deleteByProductId">
        DELETE FROM image WHERE product_id = #{productId}
    </delete>

    <delete id="deleteById">
        DELETE FROM image WHERE id = #{id}
    </delete>

</mapper>
