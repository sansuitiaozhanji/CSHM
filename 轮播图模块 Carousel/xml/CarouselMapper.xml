<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mapper.CarouselMapper">
    <resultMap id="CarouselResultMap" type="com.entity.Carousel">
        <id column="id" property="id"/>
        <result column="img_url" property="imgUrl"/>
        <result column="jump_url" property="jumpUrl"/>
        <result column="sort_num" property="sortNum"/>
        <result column="valid_start" property="validStart"/>
        <result column="valid_end" property="validEnd"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 首页有效轮播 -->
    <select id="selectValidCarousel" resultMap="CarouselResultMap">
        SELECT * FROM carousel
        WHERE status = 1
          AND NOW() BETWEEN valid_start AND valid_end
        ORDER BY sort_num DESC
    </select>

    <!-- 分页查询全部 -->
    <select id="selectAll" resultMap="CarouselResultMap">
        SELECT * FROM carousel
        ORDER BY sort_num DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="selectById" resultMap="CarouselResultMap">
        SELECT * FROM carousel WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO carousel(img_url,jump_url,sort_num,valid_start,valid_end,status,create_time)
        VALUES(#{imgUrl},#{jumpUrl},#{sortNum},#{validStart},#{validEnd},#{status},NOW())
    </insert>

    <update id="update">
        UPDATE carousel SET
            img_url = #{imgUrl},
            jump_url = #{jumpUrl},
            sort_num = #{sortNum},
            valid_start = #{validStart},
            valid_end = #{validEnd},
            status = #{status}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM carousel WHERE id = #{id}
    </delete>
</mapper>